APP_DOMAIN=refentra.example.com
ACME_EMAIL=ops@example.com
APP_IMAGE_TAG=v0.6.0

DB_USER=postgres
DB_PASSWORD=change-this-postgres-password
DB_NAME=refentra

REDIS_PASSWORD=change-this-redis-password

AUTH_JWT_SECRET=change-this-long-random-jwt-secret
AUTH_ACCESS_COOKIE_NAME=refentra_access_token
AUTH_REFRESH_COOKIE_NAME=refentra_refresh_token
AUTH_ACCESS_TTL_MINUTES=15
AUTH_REFRESH_TTL_HOURS=24
AUTH_MOCK_EMAIL=dev@refentra.com
AUTH_MOCK_PASSWORD=change-this-mock-password
CORS_ALLOW_ORIGINS=https://refentra.example.com
CORS_ALLOW_METHODS=GET,HEAD,POST,OPTIONS
CORS_ALLOW_HEADERS=Origin,Content-Type,Accept,Authorization,X-Requested-With
CORS_ALLOW_CREDENTIALS=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
SECURITY_ENABLE_HSTS=true
SECURITY_CONTENT_SECURITY_POLICY=default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https://refentra.example.com; font-src 'self' data:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
