STITCH_API_KEY=your_stitch_api_key_here
GOOGLE_CLOUD_PROJECT=your_google_cloud_project_id_here
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=refentra
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Seoul
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0
AUTH_JWT_SECRET=refentra-dev-secret
AUTH_ACCESS_COOKIE_NAME=refentra_access_token
AUTH_REFRESH_COOKIE_NAME=refentra_refresh_token
AUTH_ACCESS_TTL_MINUTES=15
AUTH_REFRESH_TTL_HOURS=24
AUTH_COOKIE_SECURE=false
AUTH_MOCK_EMAIL=dev@refentra.com
AUTH_MOCK_PASSWORD=password123
CORS_ALLOW_ORIGINS=http://localhost:4173,http://127.0.0.1:4173,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
CORS_ALLOW_METHODS=GET,HEAD,POST,OPTIONS
CORS_ALLOW_HEADERS=Origin,Content-Type,Accept,Authorization,X-Requested-With
CORS_ALLOW_CREDENTIALS=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
SECURITY_ENABLE_HSTS=false
SECURITY_CONTENT_SECURITY_POLICY=default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https:; font-src 'self' data:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
